---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const cases = await getCollection("cases");
const pad = (n: number) => String(n).padStart(2, "0");
---

<BaseLayout
  title="Case Studies · Francisco Sánchez Nieves"
  description="Proyectos anonimizados de transformación, IA y Salesforce. El problema, el rol, el enfoque y el resultado."
  canonical="https://franciscosancheznieves.com/cases"
>
  <Header />

  <main>
    <section class="phero wrap" data-screen-label="Cases hero">
      <nav class="crumbs" aria-label="Migas de pan">
        <a href="/">Inicio</a><span class="sep" aria-hidden="true">/</span><span aria-current="page">Case Studies</span>
      </nav>
      <h1 class="phero__title reveal-up">Selected Work</h1>
      <p class="phero__lead reveal-up">
        Proyectos anonimizados de transformación, IA y Salesforce. Sin logos ni información
        confidencial — solo el problema, el rol, el enfoque y el resultado.
      </p>
    </section>

    <section class="listing wrap" data-screen-label="Cases list">
      <div class="cases">
        {
          cases.map((c, i) => (
            <article class="case reveal-up">
              <div class="case__media">
                <div class="case__num">CS/{pad(i + 1)}</div>
                <div class="ph ph--duotone case__img">
                  <div class="ph__label">[ {c.data.category} ]</div>
                </div>
                <div class="case__cat">
                  <span class="tag">{c.data.category}</span>
                </div>
              </div>
              <div class="case__head">
                <h3 class="case__title">{c.data.title}</h3>
              </div>
              <p class="case__summary">{c.data.context}</p>
              <dl class="case__meta">
                <div>
                  <dt>Mi rol</dt>
                  <dd>{c.data.role}</dd>
                </div>
                <div>
                  <dt>Approach</dt>
                  <dd>{c.data.approach}</dd>
                </div>
                <div class="case__meta-wide">
                  <dt>Resultado</dt>
                  <dd>{c.data.result}</dd>
                </div>
              </dl>
              <div class="case__foot">
                <a class="tlink" href={`/cases/${c.slug}`}>
                  Leer caso <span class="arrow" aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="cta-band" data-screen-label="CTA">
      <div class="wrap cta-band__grid">
        <div>
          <p class="label reveal-fade">Next step</p>
          <h2 class="cta-band__title reveal-up">¿Tienes un reto que necesita estructura?</h2>
        </div>
        <a class="pill pill--solid reveal-up" href="/contact">
          Cuéntame tu reto <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
