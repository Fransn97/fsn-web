---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const cases = await getCollection("cases");
  return cases.map((c) => ({
    params: { slug: c.slug },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout
  title={`${entry.data.title} · Case Study`}
  description={entry.data.context}
  canonical={`https://franciscosancheznieves.com/cases/${entry.slug}`}
>
  <Header />

  <main>
    <section class="phero wrap" data-screen-label="Case hero">
      <nav class="crumbs" aria-label="Migas de pan">
        <a href="/">Inicio</a><span class="sep" aria-hidden="true">/</span>
        <a href="/cases">Case Studies</a><span class="sep" aria-hidden="true">/</span>
        <span aria-current="page">{entry.data.title}</span>
      </nav>
      <p class="phero__cat reveal-fade"><span>{entry.data.category}</span></p>
      <h1 class="phero__title reveal-up">{entry.data.title}</h1>
      <p class="phero__lead reveal-up">{entry.data.context}</p>
    </section>

    <section class="detail wrap" data-screen-label="Case body">
      <div class="detail__grid">
        <aside class="detail__aside">
          <div class="detail__aside-block">
            <span class="k">Mi rol</span>
            <span class="v">{entry.data.role}</span>
          </div>
          <div class="detail__aside-block">
            <span class="k">Tipo</span>
            <span class="v">Proyecto anonimizado</span>
          </div>
          <div class="detail__aside-block">
            <span class="k">Estado</span>
            <span class="v">Sin datos confidenciales</span>
          </div>
          {entry.data.stack && (
            <div class="detail__aside-block">
              <span class="k">Stack</span>
              <div class="stack" style="margin-top:6px">
                {entry.data.stack.map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
          )}
        </aside>
        <div class="detail__body">
          <Content />
        </div>
      </div>
    </section>

    <section class="cta-band" data-screen-label="CTA">
      <div class="wrap cta-band__grid">
        <div>
          <p class="label reveal-fade">Next step</p>
          <h2 class="cta-band__title reveal-up">¿Tienes un reto que necesita estructura?</h2>
        </div>
        <a class="pill pill--solid reveal-up" href="/contact">
          Cuéntame tu reto <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
