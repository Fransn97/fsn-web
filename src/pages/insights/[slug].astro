---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const insights = await getCollection("insights");
  return insights.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} · Field Notes`}
  description={post.data.excerpt}
  canonical={`https://franciscosancheznieves.com/insights/${post.slug}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": post.data.title,
      "author": { "@type": "Person", "name": "Francisco Sánchez Nieves" },
      "articleSection": post.data.category,
      "inLanguage": "es-ES",
      "publisher": { "@type": "Person", "name": "Francisco Sánchez Nieves" },
    })} />
  </Fragment>

  <Header />

  <main>
    <section class="phero wrap" data-screen-label="Article hero">
      <nav class="crumbs" aria-label="Migas de pan">
        <a href="/">Inicio</a><span class="sep" aria-hidden="true">/</span>
        <a href="/insights">Insights</a><span class="sep" aria-hidden="true">/</span>
        <span aria-current="page">{post.data.category}</span>
      </nav>
      <p class="phero__cat reveal-fade"><span>{post.data.category}</span></p>
      <h1 class="phero__title reveal-up">{post.data.title}</h1>
      <div class="phero__meta reveal-up">
        <div><span class="k">Lectura</span><span class="v">{post.data.readTime}</span></div>
        <div><span class="k">Tema</span><span class="v">{post.data.category}</span></div>
        <div><span class="k">Año</span><span class="v">{new Date(post.data.publishedAt).getFullYear()}</span></div>
      </div>
    </section>

    <section class="article wrap" data-screen-label="Article body">
      <div class="article__wrap">
        <p class="article__lead reveal-up">{post.data.excerpt}</p>
        <div class="article__body reveal-up">
          <Content />
        </div>
        <div class="article__author">
          <span class="article__avatar" aria-hidden="true">FSN</span>
          <p class="article__author-meta">
            <b>Francisco Sánchez Nieves</b><br />AI · Salesforce · Technology Transformation
          </p>
        </div>
      </div>
    </section>

    <section class="cta-band" data-screen-label="CTA">
      <div class="wrap cta-band__grid">
        <div>
          <p class="label reveal-fade">Next step</p>
          <h2 class="cta-band__title reveal-up">¿Tienes un reto que necesita estructura?</h2>
        </div>
        <a class="pill pill--solid reveal-up" href="/contact">
          Cuéntame tu reto <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
