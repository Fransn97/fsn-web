---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HomeBody from "../components/HomeBody.astro";
import home from "../data/home.json";
---

<BaseLayout
  title="Francisco Sánchez Nieves · IA, Salesforce & Transformación Tecnológica"
  description="Manager en Deloitte y 7 años en Salesforce. Transformación con foco en negocio e IA aplicada para Industrial, Construction y Media & Telco."
  canonical="https://franciscosancheznieves.com/"
  ogTitle="Francisco Sánchez Nieves · AI, Salesforce & Technology Transformation"
  ogDescription="Convierto problemas complejos en sistemas escalables, gobernables y medibles. IA aplicada · Salesforce · Delivery."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          name: "Francisco Sánchez Nieves",
          jobTitle: "Technology Transformation Consultant — AI & Salesforce",
          url: "https://franciscosancheznieves.com/",
          email: "hola@franciscosancheznieves.com",
          sameAs: ["https://www.linkedin.com/in/francisco-sanchez-nieves"],
          address: { "@type": "PostalAddress", addressLocality: "Madrid", addressCountry: "ES" },
          knowsAbout: ["Applied AI", "Salesforce", "Agentforce", "Data Cloud", "Experience Cloud", "CRM Transformation", "M&A IT", "Technology Delivery"],
        },
        { "@type": "WebSite", name: "Francisco Sánchez Nieves", url: "https://franciscosancheznieves.com/", inLanguage: "es-ES" },
      ],
    })} />
  </Fragment>

  <Header />
  <HomeBody lang="es" home={home} />
  <Footer />
</BaseLayout>
