---
/**
 * StyledImage — imagen con el tratamiento visual de la marca (duotono/grayscale).
 * Reemplaza al antiguo <image-slot> (que solo funcionaba en el entorno de diseño).
 * El `src` viene del CMS. Si no hay imagen, muestra un placeholder con estilo.
 */
interface Props {
  src?: string | null;
  alt?: string;
  tag?: string; // badge tipo "FSN" en la esquina
  ratio?: string; // aspect-ratio CSS, ej "3 / 4"
  placeholder?: string; // texto del estado vacío
  class?: string;
  loading?: "lazy" | "eager";
}

const {
  src,
  alt = "",
  tag,
  ratio,
  placeholder = "Imagen",
  class: className = "",
  loading = "lazy",
} = Astro.props;

const styleAttr = ratio ? `aspect-ratio:${ratio}` : undefined;
---

<figure class={`simg ${className}`} style={styleAttr}>
  {tag && <span class="simg__tag">{tag}</span>}
  {
    src ? (
      <img class="simg__img" src={src} alt={alt} loading={loading} />
    ) : (
      <div class="simg__empty">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <path d="m21 15-5-5L5 21" />
        </svg>
        <span class="simg__empty-label">{placeholder}</span>
      </div>
    )
  }
  <span class="simg__overlay" aria-hidden="true"></span>
</figure>

<style>
  .simg {
    position: relative;
    margin: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: linear-gradient(135deg, #dad7cd 0%, #cdc9be 100%);
    border: 1px solid var(--line);
  }

  /* Tratamiento de marca: escala de grises + contraste (= "estilo de la web") */
  .simg__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.04) brightness(1.01);
  }

  /* Overlay duotono: gradientes en multiply, como el sistema original */
  .simg__overlay {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(120% 90% at 28% 18%, rgba(255, 255, 255, 0.28), transparent 55%),
      radial-gradient(90% 80% at 82% 92%, rgba(26, 26, 23, 0.22), transparent 58%);
    mix-blend-mode: multiply;
  }

  /* Estado vacío con estilo (mejor que el placeholder roto anterior) */
  .simg__empty {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #5d5a50;
    text-align: center;
    padding: 16px;
  }
  .simg__empty svg {
    opacity: 0.45;
  }
  .simg__empty-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .simg__tag {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 3;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-ink);
    background: var(--accent);
    padding: 5px 10px;
  }
</style>
