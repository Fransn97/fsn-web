---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  bodyClass = "imgmode-duotone",
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;

import { getLangFromUrl } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const ogLocale = lang === "en" ? "en_US" : "es_ES";

// CSS bundled by Astro (content-hashed URL → auto cache-busting on every change)
import "../styles/styles.css";
import "../styles/pages.css";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo+Black&family=JetBrains+Mono:wght@400;500;600&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    <script src="/assets/motion.js" is:inline></script>
    <slot name="scripts" />
    <script>
      const y = document.getElementById("year");
      if (y) y.textContent = String(new Date().getFullYear());
    </script>
    <script is:inline>
      // Failsafe: si alguna animación de entrada no se dispara (IO diferido,
      // pestaña en background, etc.), revela el contenido para que NUNCA
      // quede invisible. La animación normal sigue funcionando si llega antes.
      (function () {
        function revealAll() {
          document
            .querySelectorAll(".reveal:not(.is-in),.reveal-up:not(.is-in),.reveal-fade:not(.is-in),[data-stagger]:not(.is-in)")
            .forEach(function (el) { el.classList.add("is-in"); });
        }
        setTimeout(revealAll, 2500);
        document.addEventListener("visibilitychange", function () {
          if (!document.hidden) setTimeout(revealAll, 400);
        });
      })();
    </script>
  </body>
</html>
